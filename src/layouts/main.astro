---
import '../../generated/fonts.css';
import '../site-components/global.css';
import '../styles/global.css';
import Navigation from '../components/Navigation';
import Footer from '../components/Footer';

const { pageClass = '' } = Astro.props;
---

<html lang="en" class={pageClass}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Academic Planner</title>
	</head>
	<!-- Dark mode class injection point - will be replaced with `dark` class based on your site palette -->
	<body class="__DARK_MODE_CLASS__ flex flex-col min-h-screen">
		<Navigation client:load />
		<main class="flex-1">
			<slot />
		</main>
		<Footer client:load />
	</body>
</html>

<style is:global>
  /* Page-specific overrides */
  html.splash main { 
    display: flex !important; 
  }
  
  html.splash ol,
  html.splash ul { 
    padding-left: 0 !important; 
    margin: 0 !important; 
  }
</style>
